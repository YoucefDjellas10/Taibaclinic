    <!-- ═══ ACTION ═══ -->
    <record id="action_ad_record" model="ir.actions.act_window">
        <field name="name">Publicités (Ads)</field>
        <field name="res_model">ad.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══ DEPOSITS LIST (standalone) ═══ -->
    <record id="view_campaign_deposit_list" model="ir.ui.view">
        <field name="name">campaign.deposit.list</field>
        <field name="model">campaign.deposit</field>
        <field name="arch" type="xml">
            <list string="Dépôts" decoration-info="platform == 'meta'"
                  decoration-success="platform == 'google'">
                <field name="date"/>
                <field name="campaign_id"/>
                <field name="platform"/>
                <field name="amount" sum="Total déposé"/>
                <field name="payment_method"/>
                <field name="reference"/>
                <field name="responsible_id"/>
            </list>
        </field>
    </record>

    <record id="view_campaign_deposit_form" model="ir.ui.view">
        <field name="name">campaign.deposit.form</field>
        <field name="model">campaign.deposit</field>
        <field name="arch" type="xml">
            <form string="Dépôt Budget">
                <sheet>
                    <group>
                        <group>
                            <field name="campaign_id"/>
                            <field name="date"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="payment_method"/>
                            <field name="reference"/>
                            <field name="responsible_id"/>
                        </group>
                    </group>
                    <group string="Note">
                        <field name="note" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_campaign_deposit" model="ir.actions.act_window">
        <field name="name">Dépôts Budgets</field>
        <field name="res_model">campaign.deposit</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>