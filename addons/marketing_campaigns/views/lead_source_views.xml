<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_lead_source_list" model="ir.ui.view">
        <field name="name">lead.source.list</field>
        <field name="model">lead.source</field>
        <field name="arch" type="xml">
            <list string="Sources de Leads" editable="top">
                <field name="name"/>
                <field name="platform"/>
                <field name="description"/>
                <field name="campaign_count"/>
                <field name="active" widget="toggle_button"/>
            </list>
        </field>
    </record>

    <record id="view_lead_source_form" model="ir.ui.view">
        <field name="name">lead.source.form</field>
        <field name="model">lead.source</field>
        <field name="arch" type="xml">
            <form string="Source Lead">
                <sheet>
<!--                    <div class="oe_button_box" name="button_box">-->
<!--                        <button type="object" name="action_view_campaigns"-->
<!--                                class="oe_stat_button" icon="fa-bullhorn"-->
<!--                                invisible="campaign_count == 0">-->
<!--                            <field name="campaign_count" widget="statinfo" string="Campagnes"/>-->
<!--                        </button>-->
<!--                    </div>-->
                    <group>
                        <field name="name"/>
                        <field name="platform"/>
                        <field name="active"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lead_source" model="ir.actions.act_window">
        <field name="name">Sources de Leads</field>
        <field name="res_model">lead.source</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>