<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="view_access_manage_list" model="ir.ui.view">
        <field name="name">access.manage.list</field>
        <field name="model">access.manage</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone_number"/>
                <field name="group_list" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_access_manage_form" model="ir.ui.view">
        <field name="name">access.manage.form</field>
        <field name="model">access.manage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone_number"/>
                        <field name="password" password="True"/>
                        <field name="group_list" widget="many2many_tags"/>
                        <field name="user_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_access_manage" model="ir.actions.act_window">
        <field name="name">User Manage</field>
        <field name="res_model">access.manage</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ACTION SERVEUR : synchroniser les utilisateurs manquants -->
    <record id="action_sync_missing_users" model="ir.actions.server">
        <field name="name">Synchroniser les utilisateurs manquants</field>
        <field name="model_id" ref="model_access_manage"/>
        <field name="binding_model_id" ref="model_access_manage"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">model.action_sync_missing_users()</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_access_manage_root"
              name="User Manage"
              sequence="100"/>

    <menuitem id="menu_access_manage"
              name="User Manage"
              parent="menu_access_manage_root"
              action="action_access_manage"
              sequence="10"/>

</odoo>
