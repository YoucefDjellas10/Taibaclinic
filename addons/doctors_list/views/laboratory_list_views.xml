<odoo>
    <record id="laboratory_list_form" model="ir.ui.view">
        <field name="name">laboratory.list.form</field>
        <field name="model">laboratory.list</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="laboratory_list_list" model="ir.ui.view">
        <field name="name">laboratory.list.list</field>
        <field name="model">laboratory.list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="laboratory_list_action" model="ir.actions.act_window">
        <field name="name">Laboratory list</field>
        <field name="res_model">laboratory.list</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="laboratory_list_list_sub"
              name="Laboratory list"
              action="laboratory_list_action"
              parent="menu_dental_labo_main"
              sequence="100"/>

</odoo>