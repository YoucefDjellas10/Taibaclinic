<odoo>

    <record id="seq_prescription" model="ir.sequence">
        <field name="name">Prescription</field>
        <field name="code">patient.prescription</field>
        <field name="prefix">RX/</field>
        <field name="padding">4</field>
    </record>

    <record id="seq_prescription_ordre" model="ir.sequence">
        <field name="name">Prescription N° d'ordre</field>
        <field name="code">patient.prescription.ordre</field>
        <field name="suffix">/19</field>
        <field name="padding">0</field>
        <field name="number_next">1390</field>
        <field name="number_increment">1</field>
    </record>

</odoo>