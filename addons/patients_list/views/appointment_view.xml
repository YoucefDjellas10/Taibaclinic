<odoo>
    <record id="appointment_record_form" model="ir.ui.view">
        <field name="name">appointment.record.form</field>
        <field name="model">appointment.record</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                            name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'scheduled'"
                    />
                    <button
                            name="action_start"
                            string="Start Treatment"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'confirmed'"
                    />
                    <button
                            name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="status in ('in_progress', 'completed', 'cancelled')"
                    />
                    <button
                            name="action_reset"
                            string="Reset to Scheduled"
                            type="object"
                            invisible="status != 'cancelled'"
                    />

                    <field
                            name="status"
                            widget="statusbar"
                            statusbar_visible="scheduled,confirmed,in_progress,completed"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="patient"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="reason"/>
                            <field name="status"/>
                            <field name="note"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Treatments">
                            <field name="lines_ids">
                                <list editable="bottom">
                                    <field name="treatment"/>
                                    <field name="teeth" widget="many2many_tags"/>
                                    <field name="quantity"/>
                                    <field name="currency" optional="hide"/>
                                    <field name="price"/>
                                    <field name="total"/>
                                </list>
                            </field>
                            <group>
                                <group>
                                </group>
                                <group>
                                    <group>
                                    </group>
                                    <group>
                                        <field name="gross_total"/>
                                        <field name="discount"/>
                                        <field name="net_total"/>
                                    </group>
                                </group>
                            </group>
                        </page>
                        <page string="Payments">
                            <div>
                                <button name="action_add_payment"
                                        string="Add Payment"
                                        type="object"
                                        icon="fa-money"
                                        class="btn-payment"/>
                            </div>
                            <field name="payment_ids" readonly="1">
                                <list>
                                    <field name="name" optional="hide"/>
                                    <field name="patient" optional="hide"/>
                                    <field name="appointment" optional="hide"/>
                                    <field name="create_uid"/>
                                    <field name="create_date"/>
                                    <field name="currency" optional="hide"/>
                                    <field name="amount"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Deal">
                            <div>
                                <button name="action_add_deals"
                                        string="Add Deal"
                                        type="object"
                                        icon="fa-calculator"
                                        class="btn-deal"/>
                            </div>
                            <field name="deal_ids" readonly="1">
                                <list>
                                    <field name="name" optional="hide"/>
                                    <field name="patient" optional="hide"/>
                                    <field name="appointment" optional="hide"/>
                                    <field name="status"/>
                                    <field name="create_date"/>
                                    <field name="deal_date"/>
                                    <field name="net_total"/>
                                    <field name="currency" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="appointment_record_list" model="ir.ui.view">
        <field name="name">appointment.record.list</field>
        <field name="model">appointment.record</field>
        <field name="arch" type="xml">
            <list default_order="date desc">
                <field name="create_uid"/>
                <field name="date"/>
                <field name="reason" widget="badge"/>
                <field name="status" widget="badge"
                       decoration-info="status == 'in_progress'"
                       decoration-danger="status == 'cancelled'"
                       decoration-warning="status == 'confirmed'"
                       decoration-success="status == 'completed'"/>
                <field name="net_total"/>
                <field name="note"/>
            </list>
        </field>
    </record>
    <record id="appointment_record_calendar" model="ir.ui.view">
        <field name="name">appointment.record.calendar</field>
        <field name="model">appointment.record</field>
        <field name="arch" type="xml">
            <calendar string="Appointments Calendar"
                      date_start="date"

                      mode="week">
                <field name="name"/>
                <field name="patient"/>
                <field name="status"/>

            </calendar>
        </field>
    </record>

    <record id="appointment_record_search" model="ir.ui.view">
        <field name="name">appointment.record</field>
        <field name="model">appointment.record</field>
        <field name="arch" type="xml">
            <search>
                <searchpanel>
                    <field name="status" icon="fa-cogs"/>
                    <field name="reason" icon="fa-sun"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="appointment_record_action" model="ir.actions.act_window">
        <field name="name">Appointments list</field>
        <field name="res_model">appointment.record</field>
        <field name="view_mode">list,calendar,form</field>
    </record>

    <menuitem id="appointment_record_sub"
              name="Appointment List"
              parent="patient_list_main"
              action="appointment_record_action"
              sequence="1"/>

    <record id="action_today_appointments" model="ir.actions.client">
        <field name="name">Today's Appointments</field>
        <field name="tag">today_appointments_action</field>
    </record>
    <menuitem id="to_day_appointment_record_main"
              name="Daily Appointment"
              action="action_today_appointments"
              sequence="1"/>


</odoo>