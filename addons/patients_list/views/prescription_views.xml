<odoo>

    <!-- ACTION -->
    <record id="action_prescription" model="ir.actions.act_window">
        <field name="name">Prescriptions</field>
        <field name="res_model">patient.prescription</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_medical_root" name="Medical"/>
    <menuitem id="menu_prescription"
              name="Prescriptions"
              parent="menu_medical_root"
              action="action_prescription"/>

    <!-- list -->
    <record id="view_prescription_list" model="ir.ui.view">
        <field name="name">patient.prescription.list</field>
        <field name="model">patient.prescription</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_name"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_prescription_form" model="ir.ui.view">
        <field name="name">patient.prescription.form</field>
        <field name="model">patient.prescription</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="%(action_prescription_report)d"
                            string="Print"
                            type="action"
                            class="btn-primary"/>
                </header>

                <sheet>

                    <group>
                        <field name="name" readonly="1"/>
                        <field name="patient_id"/>
                        <field name="doctor_name"/>
                        <field name="date"/>
                    </group>

                    <notebook>

                        <page string="Medications">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="medication_id"/>
                                    <field name="dosage"/>
                                    <field name="frequency"/>
                                    <field name="duration"/>
                                    <field name="instructions"/>
                                </list>
                            </field>
                        </page>

                        <page string="Notes">
                            <field name="note"/>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

</odoo>