<odoo>
    <record id="patients_form" model="ir.ui.view">
        <field name="name">patients.form</field>
        <field name="model">patients</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_quotation"
                            string="Quotation"
                            type="object"
                            class="btn-quotation"
                            invisible="stage != 'quotation_preparation'"
                    />
                    <button name="action_qualified"
                            string="Qualified"
                            type="object"
                            class="btn-success"
                            invisible="stage not in ('new', 'contacted')"
                    />
                    <button name="action_details_received"
                            string="Details received"
                            type="object"
                            class="btn-info"
                            invisible="stage != 'qualified'"
                    />
                    <button name="action_add_contact"
                            string="Add Contact"
                            type="object"
                            icon="fa-address-book"
                            class="btn-contact"
                            invisible="stage not in ('new', 'contacted')"
                    />
                    <button name="action_not_interested"
                            string="Not interested"
                            type="object"
                            class="btn-danger"
                            invisible="stage not in ('new', 'contacted')"
                    />
                    <button name="action_resend"
                            string="Resend"
                            type="object"
                            class="btn-secondary"
                            invisible="stage not in ('not_interested', 'lost')"
                    />
                    <button name="action_lost"
                            string="Lost"
                            type="object"
                            class="btn-danger"
                            invisible="stage not in ('qualified', 'waiting_details', 'quotation_preparation', 'negotiation')"
                    />

                    <field name="stage" widget="statusbar" statusbar_visible="new,contacted,not_interested,qualified"
                           invisible="patient_type != 'lead' or stage not in ('new', 'contacted', 'not_interested')"/>
                    <field name="stage" widget="statusbar" statusbar_visible="qualified,waiting_details,quotation_preparation,lost,deal_closed"
                           invisible="patient_type != 'lead' or stage in ('new', 'contacted', 'not_interested')"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="patient_type"/>
                            <field name="gender"/>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="birthday"/>
                            <field name="age"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="not_interested_reason" invisible="stage != 'not_interested'" readonly="1"/>
                            <field name="lost_reason_id" invisible="stage != 'lost'" readonly="1"/>
                            <field name="balance" readonly="1"/>
                            <field name="salesperson" invisible="patient_type != 'lead'"/>
                            <field name="stage"/>
                            <field name="interested_id" invisible="not interested_id"/>
                            <field name="medical_histiory" widget="many2many_tags"/>
                            <field name="email"/>
                            <field name="mobile"/>
                            <field name="country"/>
                            <field name="city"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contact">
                            <header>
                                <button name="action_add_contact"
                                        string="Add Contact"
                                        type="object"
                                        icon="fa-address-book"
                                        class="btn-contact"/>
                            </header>
                            <field name="contact_ids" readonly="1"/>
                        </page>
                        <page string="Attachments">
                            <header>
                                <button name="action_add_attachments"
                                        string="Add Attachment"
                                        type="object"
                                        icon="fa-paperclip"
                                        class="btn-attachment"/>
                            </header>
                            <field name="attachment_ids" readonly="1"/>
                        </page>
                        <page string="Appointments">
                            <header>
                                <button name="action_add_appointments"
                                        string="Add Appointment"
                                        type="object"
                                        icon="fa-calendar"
                                        class="btn-appointment"/>
                            </header>
                            <field name="appointment_ids" readonly="1"/>
                        </page>
                        <page string="Quotations" invisible="patient_type == 'door'">
                            <header>
                                <button name="action_add_quotations"
                                        string="Add Quotation"
                                        type="object"
                                        icon="fa-file-text-o"
                                        class="btn-quotation"/>
                            </header>
                            <field name="quotation_ids" readonly="1">
                                <list>
                                    <field name="stage"/>
                                    <field name="quotation_date"/>
                                    <field name="net_total"/>
                                    <field name="currency" optional="hide"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Deals">
                            <header>
                                <button name="action_add_deals"
                                        string="Add Deal"
                                        type="object"
                                        icon="fa-calculator"
                                        class="btn-deal"/>
                            </header>
                            <field name="deal_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="create_date"/>
                                    <field name="deal_date"/>
                                    <field name="net_total"/>
                                    <field name="currency" optional="hide"/>
                                </list>
                            </field>
                            <group>
                                <group>

                                </group>
                                <group>
                                    <group>

                                    </group>
                                    <group>
                                        <field name="deal_total" readonly="1"/>
                                    </group>
                                </group>
                            </group>
                        </page>
                        <page string="Payments">
                            <header>
                                <button name="action_add_payment"
                                        string="Add Payment"
                                        type="object"
                                        icon="fa-money"
                                        class="btn-payment"/>
                            </header>
                            <field name="payment_ids"/>
                            <group>
                                <group>

                                </group>
                                <group>
                                    <field name="payment_total" readonly="1"/>
                                    <field name="currency" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <record id="patients_list" model="ir.ui.view">
        <field name="name">patients.list</field>
        <field name="model">patients</field>
        <field name="arch" type="xml">
            <list>
                <field name="patient_type"/>
                <field name="name"/>
                <field name="age"/>
                <field name="email"/>
                <field name="mobile"/>
                <field name="city"/>
                <field name="salesperson" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="patients_search" model="ir.ui.view">
        <field name="name">patients.search</field>
        <field name="model">patients</field>
        <field name="arch" type="xml">
            <search>
                <searchpanel>
                    <field name="patient_type" icon="fa-cogs"/>
                </searchpanel>
                <field name="name"/>
                <field name="email"/>
                <field name="mobile"/>
            </search>
        </field>
    </record>


    <record id="patient_list_action" model="ir.actions.act_window">
        <field name="name">Patient list</field>
        <field name="res_model">patients</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="patient_list_main"
              name="Patients"
              sequence="10"/>
    <menuitem id="patient_list_sub"
              name="Patients"
              parent="patient_list_main"
              action="patient_list_action"
              sequence="0"/>


</odoo>