<odoo>

    <record id="action_medicine" model="ir.actions.act_window">
        <field name="name">Medicines</field>
        <field name="res_model">medical.medicine</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_medicine"
              name="Medicines"
              parent="menu_medical_root"
              action="action_medicine"/>

    <record id="view_medicine_list" model="ir.ui.view">
        <field name="name">medical.medicine.list</field>
        <field name="model">medical.medicine</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_medicine_form" model="ir.ui.view">
        <field name="name">medical.medicine.form</field>
        <field name="model">medical.medicine</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

</odoo>