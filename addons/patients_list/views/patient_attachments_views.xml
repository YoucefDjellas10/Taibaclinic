<odoo>
    <record id="patient_attachments_form" model="ir.ui.view">
        <field name="name">patient.attachments.form</field>
        <field name="model">patient.attachments</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="patient"/>
                        <field name="name"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="patient_attachments_list" model="ir.ui.view">
        <field name="name">patient.attachments.list</field>
        <field name="model">patient.attachments</field>
        <field name="arch" type="xml">
            <list>
                <field name="patient"/>
                <field name="name"/>
                <field name="attachment_ids" widget="many2many_binary"/>
            </list>
        </field>
    </record>

    <record id="patient_attachments_list_action" model="ir.actions.act_window">
        <field name="name">Patient attachments</field>
        <field name="res_model">patient.attachments</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="patient_attachments_list_sub_menu"
              name="Patient attachments"
              parent="patient_list_main"
              action="patient_attachments_list_action"
              sequence="500"/>
</odoo>