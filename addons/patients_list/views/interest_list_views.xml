<odoo>
    <record id="interest_record_form" model="ir.ui.view">
        <field name="name">interest.record.form</field>
        <field name="model">interest.record</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                </group>
            </form>
        </field>
    </record>
    <record id="interest_record_list" model="ir.ui.view">
        <field name="name">interest.record.list</field>
        <field name="model">interest.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="interest_record_action" model="ir.actions.act_window">
        <field name="name">Interest list</field>
        <field name="res_model">interest.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="interest_record_sub"
              name="Interest list"
              parent="configuration_list_main"
              action="interest_record_action"
              sequence="90"/>


</odoo>