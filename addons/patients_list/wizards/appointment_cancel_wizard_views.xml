<odoo>
    <record id="view_appointment_cancel_wizard_form" model="ir.ui.view">
        <field name="name">appointment.cancel.wizard.form</field>
        <field name="model">appointment.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Appointment">
                <sheet>
                    <group>
                        <field name="appointment_id" invisible="1" readonly="1"/>
                    </group>
                    <group>
                        <field
                                name="cancel_reason"
                                placeholder="Please explain why this appointment is being cancelled..."
                        />
                    </group>
                </sheet>
                <footer>
                    <button
                            name="action_confirm_cancel"
                            string="Confirm Cancellation"
                            type="object"
                            class="btn-danger"
                    />
                    <button
                            string="Discard"
                            class="btn-secondary"
                            special="cancel"
                    />
                </footer>
            </form>
        </field>
    </record>
</odoo>
