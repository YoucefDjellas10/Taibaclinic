<odoo>
    <record id="view_qualified_wizard_form" model="ir.ui.view">
        <field name="name">qualified.wizard.form</field>
        <field name="model">qualified.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Appointment">
                <sheet>
                    <group>
                        <field name="patient_id" invisible="1" readonly="1"/>
                    </group>
                    <group>
                        <field name="interested_id"/>
                        <field name="medical_histiory" widget="many2many_tags"/>
                        <field name="gender"/>
                        <field name="birthday"/>
                    </group>
                </sheet>
                <footer>
                    <button
                            name="action_confirm_action"
                            string="Confirm"
                            type="object"
                            class="btn-danger"
                    />
                    <button
                            string="Discard"
                            class="btn-secondary"
                            special="cancel"
                    />
                </footer>
            </form>
        </field>
    </record>
</odoo>
