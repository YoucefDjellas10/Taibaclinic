<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="prescription_letterhead_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="base_url" t-value="env['ir.config_parameter'].sudo().get_param('web.base.url')"/>

                <div class="page" style="font-family: Arial, Helvetica, sans-serif; color:#1a1a1a; position:relative; padding-bottom:110px;">

                    <!-- EN-TETE : nom clinique + logo -->
                    <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                            <td style="width:72%; vertical-align:middle;">
                                <div style="font-size:22px; font-weight:bold; color:#1a2a4a;">TAIBA DENTAL CLINIC</div>
                                <div dir="rtl" style="font-size:13px; color:#1a2a4a; margin-top:2px;">العيادة الجماعية طبية لطب وجراحة الاسنان</div>
                            </td>
                            <td style="width:28%; text-align:right; vertical-align:middle;">
                                <img t-attf-src="#{base_url}/patients_list/static/src/img/logo.png" style="height:65px;"/>
                            </td>
                        </tr>
                    </table>

                    <hr style="border:none; border-top:1px solid #999; margin:6px 0 10px 0;"/>

                    <!-- MEDECINS AGREES -->
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:10px;">
                        <tr>
                            <td style="width:34%; vertical-align:top;">
                                <div style="font-weight:bold; font-size:11px;">Dr.Haddad I Ep LEKHCHINE</div>
                                <div style="font-size:10px;">MEDECIN DENTISTE</div>
                                <div style="font-size:10px;">N&#176; d'ordre : 1163/19</div>
                            </td>
                            <td dir="rtl" style="width:32%; text-align:center; font-size:10px; vertical-align:top;">
                                <div>قلع الأسنان والقلع الجراحي</div>
                                <div>زراعة الأسنان</div>
                                <div>تقويم و تبييض الأسنان</div>
                            </td>
                            <td style="width:34%; text-align:right; vertical-align:top;">
                                <div style="font-weight:bold; font-size:11px;">Dr.BRAFTA F</div>
                                <div style="font-size:10px;">MEDECIN DENTISTE</div>
                                <div style="font-size:10px;">N&#176; d'ordre : 1389/19</div>
                            </td>
                        </tr>
                    </table>

                    <!-- DATE -->
                    <p style="margin:14px 0 4px 0;">
                        El Eulma le :
                        <span t-esc="o.date.strftime('%d/%m/%Y') if o.date else ''"/>
                    </p>

                    <!-- PATIENT -->
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:10px;">
                        <tr>
                            <td style="width:40%; border-bottom:1px dotted #999; padding-bottom:3px;">
                                <strong>Nom :</strong> <span t-esc="o.patient_id.last_name"/>
                            </td>
                            <td style="width:35%; border-bottom:1px dotted #999; padding-bottom:3px;">
                                <strong>Pr&#233;nom :</strong> <span t-esc="o.patient_id.first_name"/>
                            </td>
                            <td style="width:25%; border-bottom:1px dotted #999; padding-bottom:3px;">
                                <strong>Age :</strong> <span t-esc="o.patient_id.age"/>
                            </td>
                        </tr>
                    </table>

                    <h2 style="font-family: Arial, Helvetica, sans-serif; font-size:20px; text-align:center; text-decoration:underline; margin:22px 0 22px 0;">Ordonnance</h2>

                    <!-- MEDICAMENTS -->
                    <div style="padding:0 4px;">
                        <t t-foreach="o.line_ids" t-as="l">
                            <div style="margin-bottom:22px; border-bottom:1px dotted #ccc; padding-bottom:14px;">
                                <div style="font-size:18px; line-height:1.3;">
                                    <span style="font-weight:bold;"><t t-esc="l_index + 1"/>. </span>
                                    <span style="font-weight:bold; font-size:22px;"><t t-esc="l.medication_id.name"/></span>
                                    <t t-if="l.dosage">
                                        <span> - <t t-esc="l.dosage"/></span>
                                    </t>
                                </div>
                                <div style="font-size:14px; color:#555; margin:5px 0 0 18px; line-height:1.4;">
                                    <t t-if="l.frequency"><t t-esc="l.frequency"/></t>
                                    <t t-if="l.duration"> pendant <t t-esc="l.duration"/></t>
                                    <t t-if="l.instructions"> &#8211; <t t-esc="l.instructions"/></t>
                                </div>
                            </div>
                        </t>
                        <t t-if="not o.line_ids">
                            <div style="text-align:center; color:#999; padding:10px 0;">
                                Aucun m&#233;dicament prescrit
                            </div>
                        </t>
                    </div>

                    <!-- SIGNATURE + PIED DE PAGE, EPINGLES EN BAS -->
                    <div style="position:fixed; bottom:0; left:0; right:0;">
                        <div style="text-align:right; padding:0 4px;">
                            <div style="display:inline-block; width:200px;">
                                <div style="height:40px;"></div>
                                <div style="border-top:1px solid #333;"></div>
                                <div style="text-align:center; font-size:11px; color:#555; padding-top:4px;">
                                    Signature du m&#233;decin
                                </div>
                            </div>
                        </div>
                        <div style="text-align:center; border-top:1px solid #999; padding-top:6px; margin-top:14px; font-size:10px;">
                            Rue Guerguite Mabrouk Goutali EL-EULMA<br/>
                            05 61 75 23 09 / 05 50 49 42 98
                        </div>
                    </div>

                </div>

            </t>
        </t>
    </template>

</odoo>
