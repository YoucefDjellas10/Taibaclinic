<odoo>

    <record id="paperformat_prescription_a5" model="report.paperformat">
        <field name="name">Prescription A5</field>
        <field name="format">A5</field>
        <field name="orientation">Portrait</field>
    </record>

    <record id="action_prescription_report" model="ir.actions.report">
        <field name="name">Prescription</field>
        <field name="model">patient.prescription</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">patients_list.prescription_report_template</field>
        <field name="report_file">patients_list.prescription_report_template</field>
        <field name="paperformat_id" ref="paperformat_prescription_a5"/>
    </record>

</odoo>