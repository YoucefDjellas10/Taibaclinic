<odoo>
    <record id="product_category_form" model="ir.ui.view">
        <field name="name">product.category.record.form</field>
        <field name="model">product.category.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_category_list" model="ir.ui.view">
        <field name="name">product.category.record.list</field>
        <field name="model">product.category.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="product_category_action" model="ir.actions.act_window">
        <field name="name">Product Categories</field>
        <field name="res_model">product.category.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="product_category_menu"
              name="Product Categories"
              parent="inventory_main"
              action="product_category_action"
              sequence="5"/>
</odoo>