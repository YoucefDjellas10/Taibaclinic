<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Material Inventory ─── -->

    <record id="view_material_inventory_list" model="ir.ui.view">
        <field name="name">material.inventory.list</field>
        <field name="model">material.inventory</field>
        <field name="arch" type="xml">
            <list string="Materials">
                <field name="reference"/>
                <field name="name"/>
                <field name="category"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_material_inventory_form" model="ir.ui.view">
        <field name="name">material.inventory.form</field>
        <field name="model">material.inventory</field>
        <field name="arch" type="xml">
            <form string="Material">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Material name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="reference"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description..."/>
                    <notebook>
                        <page string="Price History">
                            <field name="price_history_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="currency" optional="hide"/>
                                    <field name="price"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_material_inventory" model="ir.actions.act_window">
        <field name="name">Material Inventory</field>
        <field name="res_model">material.inventory</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ─── Menu ─── -->

    <menuitem
        id="menu_material_inventory_root"
        name="Material Inventory"
        sequence="20"/>

    <menuitem
        id="menu_material_inventory_list"
        name="Materials"
        parent="inventory_main"
        action="action_material_inventory"
        sequence="1"/>

</odoo>