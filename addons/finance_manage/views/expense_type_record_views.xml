<odoo>
    <record id="expense_type_record_form" model="ir.ui.view">
        <field name="name">expense.type.record.form</field>
        <field name="model">expense.type.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="expense_type_record_list" model="ir.ui.view">
        <field name="name">expense.type.record.list</field>
        <field name="model">expense.type.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="expense_type_record_action" model="ir.actions.act_window">
        <field name="name">Expense type</field>
        <field name="res_model">expense.type.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="configuration_sub"
              name="Configuration"
              parent="finance_menu"
              sequence="15"/>
    <menuitem id="expense_type_record_sub"
              name="Expense type"

              parent="finance_menu"
              action="expense_type_record_action"
              sequence="1000"/>
</odoo>