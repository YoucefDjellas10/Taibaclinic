<odoo>
    <record id="expense_record_form" model="ir.ui.view">
        <field name="name">expense.record.form</field>
        <field name="model">expense.record</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_validate"
                            string="Validate"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'draft'"/>

                    <button name="action_refuse"
                            string="Refuse"
                            type="object"
                            class="btn-danger"
                            invisible="status != 'draft'"/>

                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,validated,refused"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="Date"/>
                            <field name="currency" invisible="1"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="purchase" invisible="not purchase"/>
                            <field name="note" placeholder="Notes..."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="History" invisible="not validated_by and not refused_by">
                            <group>
                                <field name="validated_by" invisible="not validated_by"/>
                                <field name="validated_date" invisible="not validated_date"/>
                                <field name="refused_by" invisible="not refused_by"/>
                                <field name="refused_date" invisible="not refused_date"/>
                                <field name="refuse_reason" invisible="not refuse_reason"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="expense_record_list" model="ir.ui.view">
        <field name="name">expense.record.list</field>
        <field name="model">expense.record</field>
        <field name="arch" type="xml">
            <list default_order="Date desc">
                <field name="name"/>
                <field name="Date"/>
                <field name="type"/>
                <field name="currency" optional="hide"/>
                <field name="amount"/>
                <field name="note" optional="hide"/>
                <field name="status" decoration-info="status == 'draft'" widget="badge"
                       decoration-danger="status == 'refused'" decoration-success="status == 'validated'"/>
            </list>
        </field>
    </record>

    <record id="expense_record_search" model="ir.ui.view">
        <field name="name">expense.record.record</field>
        <field name="model">expense.record</field>
        <field name="arch" type="xml">
            <search>
                <filter name="draft_filter"
                    string="Draft"
                    domain="[('status', '=', 'draft')]"/>
                <searchpanel>
                    <field name="status" icon="fa-cogs"/>
                    <field name="type" icon="fa-cogs"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="expense_record_action" model="ir.actions.act_window">
        <field name="name">Expense</field>
        <field name="res_model">expense.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft_filter': 1}</field>
    </record>

    <menuitem id="expense_record_sub"
              name="Expense"
              parent="finance_menu"
              action="expense_record_action"
              sequence="11"/>
</odoo>