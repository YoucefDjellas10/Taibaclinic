<odoo>
    <record id="price_category_form" model="ir.ui.view">
        <field name="name">price.category.form</field>
        <field name="model">price.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="price_category_list" model="ir.ui.view">
        <field name="name">price.category.list</field>
        <field name="model">price.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="price_category_action" model="ir.actions.act_window">
        <field name="name">Price category</field>
        <field name="res_model">price.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="price_category_action_sub"
              name="Price Category"
              parent="finance_menu"
              action="price_category_action"
              sequence="10"/>
</odoo>