<odoo>
    <record id="supplier_record_form" model="ir.ui.view">
        <field name="name">supplier.record.form</field>
        <field name="model">supplier.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Supplier name ...."/>
                        </h1>
                    </div>

                    <group string="Financial Summary">
                        <field name="currency_id" invisible="1"/>
                        <field name="total_orders_amount"/>
                        <field name="total_paid_amount"/>
                        <field name="remaining_amount"/>
                    </group>

                    <notebook>
                        <page string="Purchase Orders">
                            <field name="purchase_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="order_date"/>
                                    <field name="status"/>
                                    <field name="payment_status"/>
                                    <field name="total"/>
                                    <field name="paid_amount"/>
                                    <field name="currency" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="supplier_record_list" model="ir.ui.view">
        <field name="name">supplier.record.list</field>
        <field name="model">supplier.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="total_orders_amount"/>
                <field name="total_paid_amount"/>
                <field name="remaining_amount"/>
                <field name="currency_id" invisible="1" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="supplier_record_action" model="ir.actions.act_window">
        <field name="name">Supplier list</field>
        <field name="res_model">supplier.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="supplier_record_action_sub"
              name="Supplier list"
              parent="finance_menu"
              action="supplier_record_action"
              sequence="1000"/>
</odoo>